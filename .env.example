# Resume Builder Environment Variables
# Copy this file to .env.local and fill in your actual values

# ===========================
# SUPABASE CONFIGURATION
# ===========================
# Get these from: Supabase Dashboard → Settings → API

# Your Supabase project URL
# Format: https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here

# Your Supabase anonymous public key
# (safe to expose in frontend code)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Supabase service role key (for server-side operations)
# WARNING: Keep this secret! Never expose in frontend code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===========================
# RAZORPAY CONFIGURATION
# ===========================
# Optional: Required only if implementing payment features
# Get these from: Razorpay Dashboard → Settings → API Keys

# Razorpay Key ID (safe to expose - used in frontend)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Razorpay Secret Key (keep secret - server-side only)
# WARNING: Keep this secret! Never expose in frontend code
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here

# ===========================
# OPTIONAL: ANALYTICS
# ===========================
# Vercel Analytics (if deployed on Vercel)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id_here

# ===========================
# ENVIRONMENT
# ===========================
# Set to 'production' or 'development'
NODE_ENV=development

# ===========================
# NOTES
# ===========================
# 1. Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
#    Only use for non-sensitive data
#
# 2. All other variables are server-side only and secure
#
# 3. Never commit .env.local to version control
#
# 4. On Vercel: Add these in Settings → Environment Variables
#
# 5. For local development:
#    - Copy this file to .env.local
#    - Fill in your actual values
#    - Restart dev server after changes
